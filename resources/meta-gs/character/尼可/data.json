    },
    "2": {
      "name": "「我要教导你，指引你应走的路」",
      "desc": [
        "元素战技圣言默示·未现之光的效果获得强化：虚己之赐还会额外提升240点攻击力（不计入该效果的攻击力加成上限），圣祝之引还会依据角色的元素类型，使附近敌人的对应元素抗性降低20%，同元素类型的元素抗性降低效果不能叠加。",
        "此外，尼可施放元素战技圣言默示·未现之光时，也会为附近的当前场上角色赋予炽光护盾。"
      ]
    },
    "3": {
      "name": "「为你身边的灯，为你前方的光」",
      "desc": [
        "元素战技圣言默示·未现之光的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "「向左或向右，无论你行往何方」",
      "desc": [
        "队伍中附近的角色拥有的虚己之赐升变为圣祝之引时，尼可还会为其赋予「先导之佑」效果，持续20秒，每名角色每17秒至多获得一次该效果。",
        "拥有「先导之佑」的角色的普通攻击、重击、下落攻击、元素战技与元素爆发造成的伤害提升，提升值相当于尼可攻击力的70%。该效果将在生效8次或持续时间结束时解除。",
        "同时命中多名敌人时，会依据命中敌人的数量消耗生效次数；队伍中具有「先导之佑」的角色，其生效次数单独计算。"
      ]
    },
    "5": {
      "name": "「我就要有话对你说，在你身旁」",
      "desc": [
        "元素爆发圣言默示·天路历程的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "「这便是正确的道路，莫要彷徨」",
      "desc": [
        "尼可拥有的虚己之赐升变为圣祝之引时，队伍中附近的所有角色拥有的虚己之赐将会一同升变为圣祝之引。所有升变后的圣祝之引不再会还原为虚己之赐。",
        "此外，拥有圣祝之引的角色造成的伤害将无视敌人40%的防御力。"
      ]
    }
  },
  "passive": [
    {
      "name": "分有",
      "desc": [
        "施放元素战技圣言默示·未现之光后的20秒内，尼可将持续「观测」队伍中自己的当前场上其他角色。受观测的角色持续处于场上3秒后，其拥有的虚己之赐效果将会升变为圣祝之引，使其额外提升300点攻击力；若受观测的角色为魔导角色，则虚己之赐效果将会直接升变为圣祝之引。",
        "除尼可外，其他角色拥有的圣祝之引将在退场时还原为虚己之赐。"
      ]
    },
    {
      "name": "慕善",
      "desc": [
        "队伍中附近的当前场上角色造成元素伤害后的8秒内，尼可自己拥有的虚己之赐将会升变为圣祝之引。"
      ]
    },
    {
      "name": "静念",
      "desc": [
        "在提瓦特，不处于战斗状态下时，若已获得当前区域的寻宝罗盘，则尼可的重击将会转而施放「御使之引」：呼唤附近的仙灵指引道路，触发等同于当前区域寻宝罗盘的效果。",
        "该效果有5秒的冷却时间，且在秘境、征讨领域、深境螺旋中无效。"
      ]
    },
    {
      "name": "魔女的前夜礼·光自暗来",
      "desc": [
        "完成魔女的课业·导引之职…？后，尼可将成为魔导角色。队伍中编入至少2名魔导角色时，将获得魔导·秘仪效果，使魔导角色获得强化。",
        "<h3>魔导·秘仪</h3>",
        "魔导角色的奥迹造影造成的伤害提升，提升值相当于尼可攻击力的150%。"
      ]
    }
