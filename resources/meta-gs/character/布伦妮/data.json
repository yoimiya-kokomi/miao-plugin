  "cons": {
    "1": {
      "name": "立下寻救的誓言，旅途由此开端",
      "desc": [
        "经过元素转化后的「狩灾誓锤」的攻击命中敌人后，将为布伦妮恢复2点元素能量，该效果每1.8秒至多触发一次。"
      ]
    },
    "2": {
      "name": "整理杂乱的包袱，元素妙力果然",
      "desc": [
        "元素爆发铃鸣·狩魔之刻中，当「诱巫饵铃」处于「寻猎」模式时，布伦妮还会获得「寻猎魔女」效果：布伦妮的攻击力提升10%；「诱巫饵铃」和经过元素转化的「狩灾誓锤」命中敌人时，还会进一步使攻击力提升5%。通过上述方式，至多使攻击力提升至40%。"
      ]
    },
    "3": {
      "name": "同旅商队过山关，眼眸景色又转",
      "desc": [
        "元素爆发铃鸣·狩魔之刻的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "循风同行回头看，影子还缺一半",
      "desc": [
        "经过元素转化的「狩灾誓锤」在命中敌人后，会再次弹起并于附近敌人处落下，对命中的敌人造成80%攻击力的对应元素类型的元素伤害。"
      ]
    },
    "5": {
      "name": "输了一百次不算，明日接着再战",
      "desc": [
        "元素战技叮铃铃·猎魔之音的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "故事结尾在这儿，念给伙伴听完",
      "desc": [
        "元素爆发铃鸣·狩魔之刻中「诱巫饵铃」的「寻猎」模式的持续时间延长4秒。",
        "此外，队伍中处于「振铃鼓舞」效果影响下的角色在对敌人触发任意元素反应后，都会使布伦妮及附近当前场上拥有「振铃鼓舞」效果的其他角色攻击力提升350点，持续5秒。"
      ]
    }
  },
  "passive": [
    {
      "name": "裁断追惩",
      "desc": [
        "元素爆发铃鸣·狩魔之刻中，处于「寻猎」模式下的「诱巫饵铃」对敌人造成伤害后，若该次伤害对敌人触发了扩散反应，则还会在敌人面前召唤出一柄依据本次扩散反应进行元素转化的「狩灾誓锤」向其砸下，造成布伦妮攻击力150%的对应类型的元素伤害，该伤害视为元素爆发伤害。"
      ]
    },
    {
      "name": "振铃同心",
      "desc": [
        "当布伦妮使用发生过元素转化的「狩灾誓锤」命中敌人后，队伍中附近的其他角色将获得持续5秒的「振铃鼓舞」效果：普通攻击、重击、下落攻击、元素战技或元素爆发对敌人造成伤害时，基于布伦妮攻击力超过1000的部分，提升本次攻击造成的伤害：每点攻击力都会使本次攻击造成的伤害提升0.01%，至多提升35%。"
      ]
    },
    {
      "name": "改装！敲敲打打！",
      "desc": [
        "合成角色天赋素材时，有10%概率额外产生一份地区相同的其他随机天赋素材，等阶与合成后获得的素材相同。"
      ]
    },
    {
      "name": "魔女的前夜礼·寻魔之誓",
      "desc": [
        "完成TEST后，布伦妮将成为魔导角色。队伍中编入至少2名魔导角色时，将获得魔导·秘仪效果，使魔导角色获得强化。",
        "<h3>魔导·秘仪</h3>",
        "队伍中处于「振铃鼓舞」效果影响下的魔导角色对敌人触发任意元素反应后，布伦妮自身的攻击力提高45%，持续5秒；若该角色触发的元素反应为扩散反应，则其自身的攻击力还将额外提高20%，持续5秒。"
      ]
    }
  ],
