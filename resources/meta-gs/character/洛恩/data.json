  "cons": {
    "1": {
      "name": "往昔微风，载满悲歌",
      "desc": [
        "洛恩的争胜上限提升至原来的250%。",
        "此外，处于奇谋状态下时，队伍中附近的其他角色通过造成伤害为洛恩积攒的争胜提升至原来的250%。"
      ]
    },
    "2": {
      "name": "凡飞翔者，皆为靶标",
      "desc": [
        "处于奇谋状态下时，施放特殊元素战技镂骨彻心或元素爆发裁罚遂成后的4秒内，洛恩将获得「破邪之刃」效果：在奇谋状态下，洛恩的下一次普通攻击或重击命中敌人时，将会额外追加进行一次攻击，造成相当于洛恩攻击力300%的冰元素范围伤害，并使队伍中附近的其他角色的元素精通提升125点，持续8秒，每4秒至多获得一次「破邪之刃」效果。"
      ]
    },
    "3": {
      "name": "唯有锋刃，能愈此伤",
      "desc": [
        "元素战技奇兵诡出的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "爱若流光，逝如欢歌",
      "desc": [
        "洛恩在奇谋状态下施放元素爆发裁罚遂成时，还会将洛恩的争胜积攒至上限。",
        "此外，洛恩切换至奇谋状态时，若元素能量：",
        "·未充满：为洛恩恢复15点元素能量；",
        "·已充满：接下来的15秒内，施放元素爆发裁罚遂成后，为洛恩恢复15点元素能量。"
      ]
    },
    "5": {
      "name": "无可窥探，无可质疑",
      "desc": [
        "元素爆发裁罚遂成的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "身沦魂销，唯余欢悦",
      "desc": [
        "施放特殊元素战技镂骨彻心或在奇谋状态下元素爆发裁罚遂成不会消耗争胜，反而会使洛恩的欢悦积攒至上限，并在下一次施放特殊元素战技镂骨彻心时，使本次奇谋状态的持续时间延长1.25秒，该效果每7秒至多触发一次。",
        "此外，上述所有伤害的暴击伤害都将提升80%。"
      ]
    }
  },
  "passive": [
    {
      "name": "禁问的训诫",
      "desc": [
        "在奇谋状态下，队伍中附近的其他角色通过造成伤害为洛恩积攒争胜时，若本次伤害如果不低于洛恩基础攻击力的4000%，则还会为洛恩额外积攒60点争胜。"
      ]
    },
    {
      "name": "戏言的杰作",
      "desc": [
        "在奇谋状态下，队伍中附近的其他角色对敌人触发冰元素相关反应后的8秒内，该角色的攻击力提升15%，洛恩的攻击力提升15%。"
      ]
    },
    {
      "name": "兴尽且去来",
      "desc": [
        "施放元素战技奇兵诡出后，洛恩还会获得9秒的「乘兴」效果：持续期间，元素战技奇兵诡出的技能等级提高1级。",
        "如果队伍中其他角色的普通攻击、元素战技或元素爆发中，任一技能等级不低于洛恩的元素战技的技能等级，则「乘兴」效果的持续时间延长6秒。",
        "每18秒至多获得一次「乘兴」效果。"
      ]
    },
    {
      "name": "魔女的前夜礼·不愈之刺",
      "desc": [
        "完成魔女的课业·诸敌之题后，洛恩将成为魔导角色。队伍中编入至少2名魔导角色时，将获得魔导·秘仪效果，使魔导角色获得强化。",
        "<h3>魔导·秘仪</h3>",
        "洛恩施放特殊元素战技镂骨彻心或元素爆发裁罚遂成时，若争胜至少为上限的50%，则洛恩的普通攻击与重击造成的伤害提升40%，持续6秒。"
      ]
    }
  ],
