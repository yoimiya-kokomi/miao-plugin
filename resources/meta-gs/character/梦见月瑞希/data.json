  "cons": {
    "1": {
      "name": "宿雾若水遥",
      "desc": [
        "梦见月瑞希处于梦浮状态下时，每3.5秒将对附近的敌人施加持续3秒的「二十三夜待」效果。处于二十三夜待状态下的敌人受到风元素伤害而触发扩散反应时，将移除该效果，使此次扩散反应对该敌人造成的伤害提升，提升值相当于梦见月瑞希元素精通的1100%。并对该敌人额外进行一次攻击，造成相当于梦见月瑞希元素精通1000%的<span style=\"color:#80FFD7FF;\">风元素伤害</span>。"
      ]
    },
    "2": {
      "name": "缠忆君影梦相见",
      "desc": [
        "进入梦浮状态时，梦见月瑞希的每点元素精通，会为附近的队伍中所有其他角色提供0.04%<span style=\"color:#FF9999FF;\">火元素</span>、<span style=\"color:#80C0FFFF;\">水元素</span>、<span style=\"color:#99FFFFFF;\">冰元素</span>与<span style=\"color:#FFACFFFF;\">雷元素</span>伤害加成，效果持续至梦浮状态结束。",
        "此外，梦见月瑞希处于梦浮状态下时，附近敌人的<span style=\"color:#FF9999FF;\">火元素抗性</span>、<span style=\"color:#80C0FFFF;\">水元素抗性</span>、<span style=\"color:#99FFFFFF;\">冰元素抗性</span>、<span style=\"color:#FFACFFFF;\">雷元素抗性</span>与<span style=\"color:#80FFD7FF;\">风元素抗性</span>降低20%。"
      ]
    },
    "3": {
      "name": "晓月又经宵",
      "desc": [
        "元素战技<span style=\"color:#FFD780FF;\">秋沙歌枕巡礼</span>的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "泉轻流花暖",
      "desc": [
        "拾取元素爆发<span style=\"color:#FFD780FF;\">安乐秘汤疗法</span>中的<span style=\"color:#FFD780FF;\">梦见风名物点心</span>时，将同时造成伤害与治疗，且会额外治疗队伍中附近的另一名生命值较低的角色，治疗量为梦见月瑞希元素精通的266%，并为梦见月瑞希恢复5点元素能量。一次<span style=\"color:#FFD780FF;\">安乐秘汤疗法</span>持续期间，至多通过这种方式恢复4次元素能量。"
      ]
    },
    "5": {
      "name": "岁云暮矣待月归",
      "desc": [
        "元素爆发<span style=\"color:#FFD780FF;\">安乐秘汤疗法</span>的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "慕念萦心间",
      "desc": [
        "梦见月瑞希处于梦浮状态下时，队伍中附近的角色触发的扩散反应造成的伤害能够造成暴击，暴击率固定为30%，暴击伤害固定为100%。",
        "基于梦见月瑞希元素精通超过500的部分，每点元素精通都会使梦见月瑞希的暴击率提升0.04%、暴击伤害提升0.16%，至多通过这种方式使梦见月瑞希的暴击率提升20%、暴击伤害提升80%。"
      ]
    }
  },
  "passive": [
    {
      "name": "名月浮声",
      "desc": [
        "梦见月瑞希在梦浮状态下触发扩散反应时，梦浮状态的持续时间延长2.5秒。该效果每0.3秒至多触发1次，在一次梦浮状态期间至多触发2次。"
      ]
    },
    {
      "name": "昼想夜梦",
      "desc": [
        "梦见月瑞希处于梦浮状态下时，队伍中附近的其他角色的元素类型为<span style=\"color:#FF9999FF;\">火元素</span>、<span style=\"color:#80C0FFFF;\">水元素</span>、<span style=\"color:#99FFFFFF;\">冰元素</span>或<span style=\"color:#FFACFFFF;\">雷元素</span>的攻击命中敌人时，梦见月瑞希的元素精通提升100点，持续4秒。"
      ]
    },
    {
      "name": "诸病无病",
      "desc": [
        "梦见月瑞希在队伍中时，队伍中自己的角色使用不具备复苏功能的恢复类料理时的回复量有概率提升30%，该效果的触发概率基于对应角色的好感等级（旅行者使用时，该效果将始终触发）。"
      ]
    },
    {
      "name": "廓然梦生",
      "desc": [
        "梦见月瑞希在梦浮状态下触发扩散反应后，本次梦浮期间，下一次对附近敌人周期性造成的<span style=\"color:#80FFD7FF;\">风元素范围伤害</span>将会提升，提升值相当于梦见月瑞希元素精通的1000%，每2.5秒至多触发一次上述效果。",
        "此外，处于梦浮状态下时，队伍中附近的角色的元素精通提升，提升值相当于梦见月瑞希自己的元素精通的10%。"
      ]
    }
