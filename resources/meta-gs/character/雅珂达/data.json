  "cons": {
    "1": {
      "name": "再来一瓶！",
      "desc": [
        "元素战技奇策·财富分配方案中，呼噜噜秘藏瓶发射的软绒绒猫猫球命中敌人时，有50%的概率进行一次弹跳，对附近的敌人造成对应元素伤害。"
      ]
    },
    "2": {
      "name": "律贼的临机应变",
      "desc": [
        "月兆·满辉：突破天赋「索酬的巧计」中，除角色数量最多的元素类型外，雅珂达还可以偷偷记录剩余元素类型中角色数量最多的元素类型，并使至多两种元素类型对应的效果生效。该效果需要解锁突破天赋「索酬的巧计」。"
      ]
    },
    "3": {
      "name": "无所依归的豪赌",
      "desc": [
        "元素爆发秘器·猎人的七道具的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "尘沙之上的野莓",
      "desc": [
        "元素爆发秘器·猎人的七道具中的猫型家用互助协调器发生元素转化时，将会为雅珂达回复4点元素能量。"
      ]
    },
    "5": {
      "name": "最伟大的财宝",
      "desc": [
        "元素战技奇策·财富分配方案的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "最渺小的幸运",
      "desc": [
        "月兆·满辉：元素战技奇策·财富分配方案中的呼噜噜秘藏瓶装满后的20秒内，队伍中附近的月兆角色的暴击率提升5%，暴击伤害提升40%。"
      ]
    }
  },
  "passive": [
    {
      "name": "月兆祝赐·檐上趱行",
      "desc": [
        "雅珂达在队伍中时，队伍的月兆将会上升一级。"
      ]
    },
    {
      "name": "索酬的巧计",
      "desc": [
        "当队伍中存在至少1名元素类型为火元素、水元素、雷元素或冰元素的角色时，将依据对应元素类型的角色数量，使元素爆发秘器·猎人的七道具中的猫型家用互助协调器获得强化。",
        "雅珂达会偷偷记录队伍中上述元素类型的角色。在这些角色中，若角色数量最多的元素类型为：",
        "·火元素：猫型家用互助协调器造成原本130%的伤害；",
        "·水元素：猫型家用互助协调器造成原本120%的治疗量；",
        "·雷元素：猫型家用互助协调器的数量增加一个；",
        "·冰元素：猫型家用互助协调器的攻击间隔减少10%。",
        "若上述元素类型的角色数量相同，则按照火元素、水元素、雷元素、冰元素的顺序进行记录。初始至多只有一种元素类型对应的效果生效。"
      ]
    },
    {
      "name": "蜜莓的嘉赏",
      "desc": [
        "元素爆发秘器·猎人的七道具中的猫型家用互助协调器对队伍中自己的当前场上角色触发治疗时，若受到治疗的角色生命值高于70%，则该角色的元素精通提升100点，持续6秒。"
      ]
    },
    {
      "name": "暗巷的黠慧",
      "desc": [
        "在挪德卡莱执行探索派遣任务时，消耗的时间缩短25%。",
        "此外，作为「秘闻馆」的雇员，雅珂达似乎可以通过某种方式获取各方的情报，而那夏镇的某些势力似乎对这些情报很有兴趣…"
      ]
    }
  ],
