  "cons": {
    "1": {
      "name": "出勃然而入寥然",
      "desc": [
        "施放元素战技天地忽然身后，兹白会立即积攒100点「时隙浮光」，且「月转时隙」模式下灵驹飞踏的最大可用次数增加至5次。",
        "此外，每次切换至「月转时隙」模式后，初次施放灵驹飞踏时，第二段攻击造成的月结晶反应伤害提升220%。"
      ]
    },
    "2": {
      "name": "化于生而死于尸",
      "desc": [
        "处于「月转时隙」模式下时，队伍中附近的所有角色造成的月结晶反应伤害提升30%。",
        "月兆·满辉：突破天赋月下素娥降仙的效果获得提升：灵驹飞踏第二段攻击造成的伤害进一步提升，提升值相当于兹白防御力的550%；该效果需要解锁突破天赋月下素娥降仙。"
      ]
    },
    "3": {
      "name": "解天韬而堕其帙",
      "desc": [
        "元素战技天地忽然身的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "魂魄往而身从之",
      "desc": [
        "处于「月转时隙」模式下时，兹白的普通攻击连击段数不会重置，且灵驹飞踏命中敌人时，兹白将获得「月涣华」效果：下一次进行普通攻击时，第四段额外攻击将造成相当于原本250%的月结晶反应伤害。"
      ]
    },
    "5": {
      "name": "明见无值至不论",
      "desc": [
        "元素爆发三垣威仪法的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "天地忽如一远行",
      "desc": [
        "处于「月转时隙」模式下时，兹白积攒「时隙浮光」的效率提升50%。",
        "此外，灵驹飞踏将转为消耗所有的「时隙浮光」，基于消耗的「时隙浮光」超过70点的部分，每额外消耗1点「时隙浮光」，都会使本次灵驹飞踏与接下来3秒内兹白造成的月结晶反应伤害擢升1.6%。该效果无法叠加。",
        "<h3>● 擢升</h3>",
        "特殊的伤害提升效果，与其他的伤害提升效果分别独立计算。"
      ]
    }
  },
  "passive": [
    {
      "name": "月兆祝赐·浮明若流",
      "desc": [
        "队伍中的角色触发水元素结晶反应时，将转为触发月结晶反应，且基于兹白的防御力，提升队伍中角色造成的月结晶反应的基础伤害：每100点防御力都将提升0.7%月结晶反应的基础伤害，至多通过这种方式提升14%伤害。",
        "此外，兹白在队伍中时，队伍的月兆将会上升一级。"
      ]
    },
    {
      "name": "月下素娥降仙",
      "desc": [
        "施放元素战技天地忽然身时，或队伍中附近的角色触发月笼谐奏时，兹白将获得持续4秒的「太阴降」效果：灵驹飞踏第二段攻击造成的伤害提升，提升值相当于兹白防御力的60%。"
      ]
    },
    {
      "name": "叠嶂峦岫出云",
      "desc": [
        "队伍中每存在一名元素类型为岩元素的其他角色，都会使兹白的防御力提升15%；队伍中每存在一名元素类型为水元素的其他角色，都会使兹白的元素精通提升60点。"
      ]
    },
    {
      "name": "花林如霰",
      "desc": [
        "在夜间（18时至6时），不处于战斗状态下时，每2秒为兹白恢复1点元素能量。",
        "该效果在秘境、征讨领域、深境螺旋中无效。"
      ]
    }
  ],
