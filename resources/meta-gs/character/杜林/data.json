  "cons": {
    "1": {
      "name": "红土之逆",
      "desc": [
        "施放元素爆发后，依据杜林施放的元素爆发，会分别造成不同的效果：",
        "·白化法·如光流变：队伍中附近的所有其他角色获得20层「轮变启迪」，持续20秒。拥有「轮变启迪」的当前场上角色的普通攻击、重击、下落攻击、元素战技或元素爆发造成伤害时，将消耗1层「轮变启迪」，提升造成的伤害，提升值相当于杜林攻击力的60%。队伍中拥有「轮变启迪」的角色，其生效次数单独计算。",
        "·黑度法·如星阴燃：杜林获得20层「轮变启迪」，持续20秒。杜林造成元素爆发伤害时，将消耗2层「轮变启迪」，提升造成的伤害，提升值相当于杜林攻击力的150%。",
        "施放元素爆发时，「轮变启迪」的层数将会刷新。"
      ]
    },
    "2": {
      "name": "无底之想",
      "desc": [
        "杜林施放元素爆发后的20秒内，队伍中附近的角色对敌人触发蒸发、融化、燃烧、超载、火元素扩散或火元素结晶反应后，或对处于燃烧状态下的敌人造成火元素伤害或草元素伤害时，队伍中附近的角色造成的火元素伤害与参与反应的对应元素伤害提升50%，持续6秒。"
      ]
    },
    "3": {
      "name": "焰镜之显",
      "desc": [
        "元素爆发白化法·如光流变的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "流溢之原",
      "desc": [
        "杜林造成的元素爆发伤害提升40%。此外，触发命之座「红土之逆」中消耗「轮变启迪」的效果时，有30%几率不会消耗「轮变启迪」。"
      ]
    },
    "5": {
      "name": "苦火之裂",
      "desc": [
        "元素战技二元式·聚分熔炼的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "双重诞生",
      "desc": [
        "杜林造成的元素爆发伤害将无视敌人30%的防御力。",
        "此外，杜林的元素爆发白化法·如光流变与黑度法·如星阴燃分别获得强化：",
        "·元素爆发白化法·如光流变与「白焰之龙」命中敌人时，该敌人的防御力降低30%，持续6秒；",
        "·元素爆发黑度法·如星阴燃与「黑蚀之龙」造成的伤害将额外无视敌人40%的防御力。"
      ]
    }
  },
  "passive": [
    {
      "name": "地涌的回音",
      "desc": [
        "在蒙德执行时长为20小时的探索派遣任务时，获得的奖励增加25%。"
      ]
    },
    {
      "name": "光灵遵神数显现",
      "desc": [
        "依据杜林施放元素爆发显现的力量形态，分别产生不同的强化效果。若杜林的力量显现为：",
        "<h3>白焰之龙</h3>",
        "队伍中附近的角色对敌人触发燃烧、超载、火元素扩散、火元素结晶反应后，或对处于燃烧状态下的敌人造成火元素伤害或草元素伤害时，该敌人的火元素抗性与参与反应的对应元素抗性降低20%，持续6秒。",
        "<h3>黑蚀之龙</h3>",
        "杜林触发的蒸发反应造成的伤害提升40%，融化反应造成的伤害提升40%。"
      ]
    },
    {
      "name": "混沌如黑夜构成",
      "desc": [
        "施放元素爆发后的20秒内，杜林将获得「肇象熔炼」效果：持续期间，杜林将获得10层「肇象」，白焰之龙与黑蚀之龙的间歇性攻击造成伤害时，将消耗1层「肇象」，提升造成的伤害，每100点攻击力都将额外造成相当于原本3%的伤害，至多通过这种方式额外造成相当于原本75%的伤害。一次白焰之龙与黑蚀之龙同时命中多名敌人时，只会消耗一层「肇象」。",
        "再次施放元素爆发时，「肇象」的层数将会刷新。"
      ]
    },
    {
      "name": "魔女的前夜礼·升华赞歌",
      "desc": [
        "完成魔女的课业·此世之题后，杜林将成为魔导角色。队伍中编入至少2名魔导角色时，将获得魔导·秘仪效果，使魔导角色获得强化。",
        "<h3>魔导·秘仪</h3>",
        "除持续时间外，突破天赋「光灵遵神数显现」中的所有效果提升75%。"
      ]
    }
  ],
