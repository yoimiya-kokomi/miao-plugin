  "cons": {
    "1": {
      "name": "谋篇乃成败之始",
      "desc": [
        "奈芙尔的幻戏造成的月绽放反应伤害的基础伤害提升，提升值相当于奈芙尔的元素精通的60%。该效果同样会受到「伪秘之帷」的加成。"
      ]
    },
    "2": {
      "name": "明察为筹算之先",
      "desc": [
        "突破天赋「月下的豪赌」的效果获得强化：「伪秘之帷」的持续时间延长5秒，上限提升至5层，且至多使幻戏造成原本140%的伤害；奈芙尔施放元素战技弈术·千夜一舞时，将立刻获得2层「伪秘之帷」。此外，「伪秘之帷」叠加至5层或5层的持续时间刷新时，奈芙尔的元素精通改为提升200点，持续8秒。",
        "需要解锁突破天赋「月下的豪赌」。"
      ]
    },
    "3": {
      "name": "诳言掩虚实之迹",
      "desc": [
        "元素战技弈术·千夜一舞的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "4": {
      "name": "眩惑入谜局之网",
      "desc": [
        "奈芙尔在场上且处于「影舞」状态下时，获取草露的速度提升25%。",
        "此外，奈芙尔处于「影舞」状态下时，还会使附近敌人的草元素抗性降低20%，当奈芙尔不处于「影舞」状态或离开敌人一定距离后，该效果会在4.5秒后移除。"
      ]
    },
    "5": {
      "name": "见机在忽微之间",
      "desc": [
        "元素爆发圣约·真眸幻戏的技能等级提高3级。",
        "至多提升至15级。"
      ]
    },
    "6": {
      "name": "决胜于逆转之时",
      "desc": [
        "奈芙尔施放幻戏时，自身的第二段伤害将转为造成相当于奈芙尔元素精通85%的草元素范围伤害；此外，幻戏的攻击结束时，还会造成一次相当于奈芙尔元素精通120%的草元素范围伤害。上述伤害均视为由幻戏造成的月绽放反应伤害。",
        "<h3>月兆·满辉</h3>",
        "奈芙尔造成的月绽放反应伤害擢升15%。",
        "<h3>● 擢升</h3>",
        "特殊的伤害提升效果，与其他的伤害提升效果分别独立计算。"
      ]
    }
  },
  "passive": [
    {
      "name": "月兆祝赐·廊下暮影",
      "desc": [
        "队伍中的角色触发绽放反应时，将转为触发月绽放反应，且基于奈芙尔的元素精通，提升队伍中角色造成的月绽放反应的基础伤害：每点元素精通都将提升0.0175%月绽放反应的基础伤害，至多通过这种方式提升14%伤害。",
        "此外，奈芙尔在队伍中时，队伍的月兆将会上升一级。"
      ]
    },
    {
      "name": "月下的豪赌",
      "desc": [
        "依据队伍的月兆，奈芙尔将获得对应的强化效果。",
        "月兆·满辉：施放元素战技弈术·千夜一舞时，将使当前场上的草原核转化为「诳言之核」，且附近所有角色在接下来的15秒内触发月绽放反应时，将取代草原核与丰穰之核产生诳言之核。诳言之核无法触发超绽放与烈绽放反应，也无法迸发。",
        "奈芙尔施放重击或幻戏时，可以吸收附近一定范围内的诳言之核，每吸收一枚诳言之核，奈芙尔便会获得一层「伪秘之帷」效果；该效果叠加至3层或3层的持续时间刷新时，奈芙尔的元素精通提升100点，持续8秒。"
      ]
    },
    {
      "name": "尘沙的女儿",
      "desc": [
        "奈芙尔处于「影舞」状态下时，队伍中的角色触发月绽放反应后的5秒内，奈芙尔的蛇行状态还会额外为队伍提供草露；依据奈芙尔的元素精通超过500的部分，每100点元素精通都将使上述提供草露的效果提升10%，至多通过这种方式提升50%。"
      ]
    },
    {
      "name": "金室的密谋",
      "desc": [
        "在挪德卡莱执行时长为20小时的探索派遣任务时，获得的奖励增加25%。",
        "此外，作为「秘闻馆」的主人，奈芙尔似乎可以通过某种方式获取各方的情报，而那夏镇的某些势力似乎对这些情报很有兴趣…"
      ]
    }
  ],
