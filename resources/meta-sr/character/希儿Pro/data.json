  "cons": {
    "1": {
      "name": "斩尽",
      "desc": "对当前生命值百分比小于等于80%的敌方目标造成伤害时，暴击率提高15%且无视目标20%的防御力。"
    },
    "2": {
      "name": "蝶舞",
      "desc": "战技的加速效果可以叠加，最多叠加2层。"
    },
    "3": {
      "name": "缭乱",
      "desc": "战技等级+2，最多不超过<nobr>15</nobr>级；天赋等级+2，最多不超过<nobr>15</nobr>级。"
    },
    "4": {
      "name": "掠影",
      "desc": "希儿消灭敌方目标时，自身恢复15点能量。"
    },
    "5": {
      "name": "锋锐",
      "desc": "终结技等级+2，最多不超过<nobr>15</nobr>级；普攻等级+1，最多不超过<nobr>10</nobr>级。"
    },
    "6": {
      "name": "离析",
      "desc": "施放终结技后使目标陷入【乱蝶】状态，持续3回合。【乱蝶】状态下的敌方目标受到攻击后，额外受到1次等同于希儿本次终结技伤害30%的真实伤害。处于【乱蝶】状态下的敌人被任意单位消灭时，也会触发希儿的天赋。\n当希儿陷入无法战斗状态时，敌方目标的【乱蝶】状态被解除。"
    }
  },
