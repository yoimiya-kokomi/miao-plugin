    "1": {
      "name": "故乡，为祈福起舞",
      "desc": "全属性抗性穿透提高<nobr>$1[i]%</nobr>，【狐狸老师】施放攻击后会额外触发一次欢愉技。欢愉技会使自身额外获得<nobr>$2[i]</nobr>点【好活当赏】。"
    },
    "2": {
      "name": "遥途，求长开不谢",
      "desc": "暴击伤害提高<nobr>$1[i]%</nobr>，触发行迹【瞰众乐】/行迹【开不败】的获得好活当赏效果时，额外获得等同于本次获得的【好活当赏】<nobr>$2[i]%</nobr>/<nobr>$3[i]%</nobr>的【好活当赏】。"
    },
    "3": {
      "name": "尺剑，吞赤月妖邪",
      "desc": "终结技等级+2，最多不超过<nobr>15</nobr>级；普攻等级+1，最多不超过<nobr>10</nobr>级；欢愉技等级+1，最多不超过<nobr>15</nobr>级。"
    },
    "4": {
      "name": "花田，遭恶徒摘落",
      "desc": "绯英造成的伤害无视敌方目标<nobr>$1[i]%</nobr>的防御力。"
    },
    "5": {
      "name": "乐园，见悲喜苦乐",
      "desc": "战技等级+2，最多不超过<nobr>15</nobr>级；天赋等级+2，最多不超过<nobr>15</nobr>级；欢愉技等级+1，最多不超过<nobr>15</nobr>级。"
    },
    "6": {
      "name": "少女，见浮生入梦",
      "desc": "绯英的【好活当赏】的持续时间增加<nobr>$2[i]</nobr>回合。绯英造成的欢愉伤害增笑<nobr>$1[i]%</nobr>，每持有<nobr>100</nobr>点【好活当赏】额外增笑<nobr>$3[f1]%</nobr>，最高计入<nobr>1000</nobr>点【好活当赏】。进入战斗首次施放终结技后，为绯英固定恢复<nobr>$4[i]</nobr>点能量，该效果每再施放<nobr>$5[i]</nobr>次终结技可触发1次。"
    }
