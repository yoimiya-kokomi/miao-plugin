  "cons": {
    "1": {
      "name": "见证一切之人",
      "desc": "当吉尔伽美什持有【王来承认】时，【王来承认】无视防御力的效果对其他队友也生效，且【王来承认】额外使吉尔伽美什攻击力提高60%。施放战技时额外固定恢复40能量。"
    },
    "2": {
      "name": "通晓万物之智",
      "desc": "吉尔伽美什进入战斗时获得5点【兴致】，施放终结技时额外获得5点【兴致】。战技【王之财宝】对主目标造成的伤害倍率提高100%，对相邻目标造成的伤害倍率提高50%。"
    },
    "3": {
      "name": "跋涉千里之旅",
      "desc": "战技等级+2，最多不超过<nobr>15</nobr>级；普攻等级+1，最多不超过<nobr>10</nobr>级。"
    },
    "4": {
      "name": "唯我独尊之王",
      "desc": "吉尔伽美什的能量恢复效率提高20%。"
    },
    "5": {
      "name": "人神诀别之剑",
      "desc": "终结技等级+2，最多不超过<nobr>15</nobr>级；天赋等级+2，最多不超过<nobr>15</nobr>级。"
    },
    "6": {
      "name": "挚友淬锻之魂",
      "desc": "终结技【天地乖离•开辟之星】的弹射伤害倍率提高80%。吉尔伽美什在场时，使我方角色的全属性抗性穿透提高20%。队友施放终结技时，吉尔伽美什获得1点【黄金律】，最多累计3点。自身施放终结技时消耗全部【黄金律】，每消耗1点【黄金律】使造成的终结技伤害的暴击伤害提高100%。"
    }
  },
