  "cons": {
    "1": {
      "name": "小心，满月不可外出",
      "desc": "不死途在场时，敌方全体受到的伤害提高<nobr>24%</nobr>。当敌方目标当前生命值百分比小于等于<nobr>50%</nobr>时，其受到的伤害提高至<nobr>36%</nobr>。"
    },
    "2": {
      "name": "敲门，屋内空余窃笑",
      "desc": "【婪酣】叠加上限提高至<nobr>18</nobr>层，每当不死途发动强化天赋<u>追加攻击</u>后，返还所移除【婪酣】层数的<nobr>35%</nobr>。"
    },
    "3": {
      "name": "沉默，老友各怀心事",
      "desc": "终结技等级+2，最多不超过<nobr>15</nobr>级；普攻等级+1，最多不超过<nobr>10</nobr>级。"
    },
    "4": {
      "name": "切记，不必咀嚼真相",
      "desc": "不死途施放终结技时，攻击力提高<nobr>40%</nobr>，持续<nobr>3</nobr>回合。"
    },
    "5": {
      "name": "提醒，侦探亦是凶手",
      "desc": "战技等级+2，最多不超过<nobr>15</nobr>级；天赋等级+2，最多不超过<nobr>15</nobr>级。"
    },
    "6": {
      "name": "结局，或许无人生还",
      "desc": "当场上存在【饲饵】时，敌方全体的全属性抗性降低<nobr>20%</nobr>。不死途每获得过1层【婪酣】，造成的伤害提高<nobr>4%</nobr>，该效果最多叠加<nobr>30</nobr>层。"
    }
  },
