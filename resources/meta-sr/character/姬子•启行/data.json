  "cons": {
    "1": {
      "name": "我们称之为路的，是开拓",
      "desc": "天赋额外发动助战技效果的次数额外增加1次。【同行协议：裁决】状态下，发动助战技所需的终结技施放次数减少1次。【同行协议：歼破】状态下，发动助战技所需的充能减少3点。姬子•启行发动助战技时，造成额外伤害的效果次数增加1次。"
    },
    "2": {
      "name": "旗帜，永不降下的帆",
      "desc": "姬子•启行助战技的使用上限提高至2次，终结技和助战技造成的伤害为原伤害的130%。【领航旗语】状态下每个回合开始时，立即额外恢复1次助战技使用次数。行迹【列车的脉搏在轰鸣】效果非开拓同行角色使用助战技时，也会获得1个额外回合。"
    },
    "3": {
      "name": "星辰之子，也在思索繁星",
      "desc": "终结技等级+2，最多不超过<nobr>15</nobr>级；普攻等级+1，最多不超过<nobr>10</nobr>级。"
    },
    "4": {
      "name": "握住所有伸向天空的手",
      "desc": "天赋【共赴灼热的远征】使用助战技时，全属性抗性穿透提高效果对我方全体生效，姬子•启行获得该效果时全属性抗性穿透额外提高10%。"
    },
    "5": {
      "name": "去跨越宇宙的全境",
      "desc": "战技等级+2，最多不超过<nobr>15</nobr>级；天赋等级+2，最多不超过<nobr>15</nobr>级。"
    },
    "6": {
      "name": "铭记，终抵群星的誓约",
      "desc": "姬子•启行火属性抗性穿透提高20%。【源能】的上限提高至6点，我方使用或发动助战技时，助战技造成的伤害提高75%，姬子•启行会获得1点【源能】。终结技期间发动【超频粒子光束】攻击时，额外获得1点【源能】。发动【轨道歼灭脉冲】时，若当前【源能】大于等于6点，则额外对敌方全体造成1次等同于姬子•启行160%攻击力的火属性伤害。"
    }
  },
